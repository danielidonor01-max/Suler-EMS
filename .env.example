# =============================================================================
# Suler EMS — Environment Configuration
# Copy to `.env` (local) or set in your hosting platform (Vercel / Render / Fly).
# Values below are the actual keys the codebase reads — if a key isn't listed,
# the code doesn't use it.
# =============================================================================


# --- REQUIRED ----------------------------------------------------------------

# Postgres connection. Local dev uses the docker-compose `db` service.
# Production: managed Postgres (Neon, Supabase, Render Postgres, Vercel Postgres).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth v5 secret. Generate with: `openssl rand -base64 32`
# Both AUTH_SECRET (v5 canonical) and NEXTAUTH_SECRET (v4 fallback) are read;
# set AUTH_SECRET — the codebase resolves either.
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Public base URL of the deployment. Required outside Vercel; on Vercel it's
# auto-injected. For local dev, the default works.
NEXTAUTH_URL="http://localhost:3000"


# --- OPTIONAL: Google OAuth SSO ----------------------------------------------
# Set ALL THREE to enable. Provider auto-skips registration if any missing.
# Callback URL to register in Google Cloud Console:
#   https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Client-side toggle that decides whether the "Sign in with Google" button
# renders on /login. Must start with NEXT_PUBLIC_ to be visible to the browser.
NEXT_PUBLIC_GOOGLE_SSO_ENABLED="false"


# --- OPTIONAL: Redis (Inngest dev / future caching) --------------------------
REDIS_URL="redis://localhost:6379"


# --- OPTIONAL: Demo / staging credentials reveal -----------------------------
# When NODE_ENV !== 'production', /login shows the seeded admin@suler.com /
# Admin123! pair as a help affordance. Setting this to 'true' surfaces the
# panel even in production builds (use for short-lived demo deploys ONLY).
NEXT_PUBLIC_SHOW_SEED_CREDENTIALS="false"


# --- OPTIONAL: Observability -------------------------------------------------

LOG_LEVEL="info"


# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# 1. Migrations DO NOT run automatically on container start. Run once after
#    each deploy that ships schema changes:
#      npx prisma migrate deploy
#    For Vercel: add to the build command. For Docker: run in a one-off task.
#
# 2. Seeding is also manual:
#      npx prisma db seed
#    Run only on fresh databases; re-running clears workflow / payroll rows.
#
# 3. The proxy.ts middleware enforces login on every route except /login,
#    /forbidden, /api/auth/*, and static assets. There is no guest mode.
#
# 4. Default landing for a fresh visit is /login. Already-authenticated users
#    are bounced from /login to /dashboard automatically.
